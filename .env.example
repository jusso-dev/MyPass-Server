# --- Required ---

# Postgres connection URL.
DATABASE_URL=postgres://mypass:mypass@localhost:5432/mypass

# HMAC-SHA256 key used to hash card owner secrets at rest. Must be hex-encoded,
# at least 256 bits (64 hex chars). Generate with: openssl rand -hex 32
HMAC_KEY=

# --- Optional ---

# HTTP port the server binds to.
PORT=3000

# Tracing filter. Examples:
#   mypass_server=info,tower_http=info        (production)
#   mypass_server=debug,tower_http=debug      (development)
RUST_LOG=mypass_server=info,tower_http=info

# Allowed CORS origin (single value, e.g. https://example.com). Leave blank to
# disable cross-origin requests entirely. Never set to `*` in production.
CORS_ORIGIN=

# --- Optional: FCM push notifications ---
# All three must be set together to enable push. The server falls back to a
# no-op (warning-logged) if any are missing.

# Firebase project ID (from your Firebase console).
FCM_PROJECT_ID=

# Service account email (firebase-adminsdk-*@<project>.iam.gserviceaccount.com).
FCM_CLIENT_EMAIL=

# Service account private key in PEM format. Use literal "\n" for newlines.
FCM_PRIVATE_KEY=
